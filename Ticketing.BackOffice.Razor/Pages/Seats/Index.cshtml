@page
@model Ticketing.BackOffice.Razor.Pages.Seats.IndexModel
@using Ticketing.Core.Models
@{
    ViewData["Title"] = "Billets";
}

<style>
.ptbl{width:100%;border-collapse:collapse}
.ptbl th{text-align:left;font-size:.75rem;font-weight:600;color:#6b7280;padding:.55rem 1rem;border-bottom:1px solid #e5e7eb;background:#f9fafb;white-space:nowrap}
.ptbl td{font-size:.85rem;color:#111827;padding:.6rem 1rem;border-bottom:1px solid #f3f4f6}
.ptbl tbody tr:last-child td{border-bottom:none}
.ptbl tbody tr:hover td{background:#f9fafb}
</style>

<div class="flex items-center justify-between mb-4">
    <h1 class="text-xl font-bold text-gray-800">Billets</h1>
    <div class="flex items-center gap-3 text-xs text-gray-500">
        <span class="px-2.5 py-1 bg-white border border-gray-200 rounded-lg">Total : <strong>@Model.TotalSeats</strong></span>
        <span class="px-2.5 py-1 bg-green-50 border border-green-100 rounded-lg text-green-700">Libres : <strong>@Model.FreeSeats</strong></span>
        <span class="px-2.5 py-1 bg-amber-50 border border-amber-100 rounded-lg text-amber-700">Réservés : <strong>@Model.ReservedSeats</strong></span>
        <span class="px-2.5 py-1 bg-blue-50 border border-blue-100 rounded-lg text-blue-700">Vendus : <strong>@Model.TakenSeats</strong></span>
    </div>
</div>

<!-- Search -->
<div class="bg-white border border-gray-200 rounded-lg mb-3 overflow-hidden">
    <div class="px-4 py-2.5 text-sm font-semibold text-gray-700 flex justify-between items-center cursor-pointer" onclick="toggleSearch()">
        <span>Recherche</span>
        <svg id="sc" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="transition:transform .2s">
            <path d="m18 15-6-6-6 6"/>
        </svg>
    </div>
    <div id="sb" class="px-4 py-3 border-t border-gray-100">
        <form method="get" class="flex flex-wrap gap-2 items-center">
            <input type="text" name="searchTerm" value="@Model.SearchTerm" placeholder="Code, client, référence…"
                   class="border border-gray-200 rounded-lg px-3 py-2 text-sm outline-none focus:border-blue-400 min-w-[200px]" />
            <select name="eventId" class="border border-gray-200 rounded-lg px-3 py-2 text-sm outline-none focus:border-blue-400">
                <option value="">Tous les événements</option>
                @foreach (var ev in Model.Events)
                {
                    <option value="@ev.Id" selected="@(Model.SelectedEventId == ev.Id)">@ev.Name</option>
                }
            </select>
            <select name="status" class="border border-gray-200 rounded-lg px-3 py-2 text-sm outline-none focus:border-blue-400">
                <option value="">Tous les statuts</option>
                <option value="Free" selected="@(Model.SelectedStatus == SeatStatus.Free)">Libre</option>
                <option value="Reserved" selected="@(Model.SelectedStatus == SeatStatus.Reserved)">Réservé</option>
                <option value="Taken" selected="@(Model.SelectedStatus == SeatStatus.Taken)">Vendu</option>
            </select>
            <button type="submit" class="px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700">Rechercher</button>
            <a asp-page="Index" class="px-4 py-2 border border-gray-300 text-gray-600 text-sm font-semibold rounded-lg hover:bg-gray-50">Réinitialiser</a>
        </form>
    </div>
</div>

<!-- Table -->
<div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <div class="px-4 py-2 border-b border-gray-100">
        <span class="text-xs text-gray-400">@Model.TotalSeats résultat(s)</span>
    </div>
    <div class="overflow-x-auto">
        <table class="ptbl">
            <thead>
                <tr>
                    <th style="width:44px">#</th>
                    <th>Code</th>
                    <th class="hidden sm:table-cell">Événement</th>
                    <th class="hidden md:table-cell">Type / Prix</th>
                    <th>Statut</th>
                    <th class="hidden lg:table-cell">Client</th>
                    <th class="hidden lg:table-cell">Référence</th>
                </tr>
            </thead>
            <tbody>
                @{ int idx = (Model.CurrentPage - 1) * 10 + 1; }
                @foreach (var s in Model.Seats)
                {
                    <tr>
                        <td class="text-gray-400 text-xs">@idx</td>
                        <td class="font-mono font-semibold text-sm">@s.Code</td>
                        <td class="hidden sm:table-cell text-gray-600 text-xs">@s.EventName</td>
                        <td class="hidden md:table-cell text-gray-500 text-xs">@s.TicketTypeName — @s.Price.ToString("N0") Ar</td>
                        <td>
                            @switch (s.Status)
                            {
                                case SeatStatus.Free:
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700">
                                        <span class="w-1.5 h-1.5 rounded-full bg-green-500 inline-block"></span>Libre
                                    </span>
                                    break;
                                case SeatStatus.Reserved:
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700">
                                        <span class="w-1.5 h-1.5 rounded-full bg-amber-400 inline-block"></span>Réservé
                                    </span>
                                    break;
                                case SeatStatus.Taken:
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">
                                        <span class="w-1.5 h-1.5 rounded-full bg-blue-500 inline-block"></span>Vendu
                                    </span>
                                    break;
                                default:
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
                                        <span class="w-1.5 h-1.5 rounded-full bg-gray-400 inline-block"></span>@s.Status
                                    </span>
                                    break;
                            }
                        </td>
                        <td class="hidden lg:table-cell text-gray-500 text-xs">@(s.CustomerName ?? "—")</td>
                        <td class="hidden lg:table-cell font-mono text-xs text-blue-600">@(s.ReservationReference ?? "—")</td>
                    </tr>
                    idx++;
                }
                @if (!Model.Seats.Any())
                {
                    <tr><td colspan="7" class="text-center text-gray-400 py-10 text-sm">Aucun billet trouvé</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="px-4 py-2.5 border-t border-gray-100 flex items-center justify-between text-xs text-gray-500">
            <span>Page @Model.CurrentPage / @Model.TotalPages</span>
            <div class="flex gap-1">
                @if (Model.HasPreviousPage)
                {
                    <a asp-page="Index" asp-route-page="@(Model.CurrentPage-1)" asp-route-searchTerm="@Model.SearchTerm"
                       asp-route-eventId="@Model.SelectedEventId" asp-route-status="@Model.SelectedStatus"
                       class="px-2.5 py-1 border border-gray-200 rounded hover:bg-gray-50">‹</a>
                }
                @for (int p = Math.Max(1, Model.CurrentPage-2); p <= Math.Min(Model.TotalPages, Model.CurrentPage+2); p++)
                {
                    <a asp-page="Index" asp-route-page="@p" asp-route-searchTerm="@Model.SearchTerm"
                       asp-route-eventId="@Model.SelectedEventId" asp-route-status="@Model.SelectedStatus"
                       class="px-2.5 py-1 border rounded @(p==Model.CurrentPage?"bg-blue-600 text-white border-blue-600":"border-gray-200 hover:bg-gray-50")">@p</a>
                }
                @if (Model.HasNextPage)
                {
                    <a asp-page="Index" asp-route-page="@(Model.CurrentPage+1)" asp-route-searchTerm="@Model.SearchTerm"
                       asp-route-eventId="@Model.SelectedEventId" asp-route-status="@Model.SelectedStatus"
                       class="px-2.5 py-1 border border-gray-200 rounded hover:bg-gray-50">›</a>
                }
            </div>
        </div>
    }
</div>

<script>
function toggleSearch(){
    const b=document.getElementById('sb'),c=document.getElementById('sc');
    const h=b.style.display==='none';
    b.style.display=h?'':'none';
    c.style.transform=h?'':'rotate(180deg)';
}
</script>
