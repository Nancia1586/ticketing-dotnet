@page
@model Ticketing.BackOffice.Razor.Pages.Account.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Connexion";
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Tiktek Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"></noscript>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .papi-input {
            width: 100%;
            padding: 0.85rem 1rem;
            border: 1.5px solid #e2e8f0;
            border-radius: 8px;
            font-size: 0.95rem;
            color: #1e293b;
            background: #ffffff;
            outline: none;
            transition: border-color .2s, box-shadow .2s;
            font-family: inherit;
        }
        .papi-input:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
        }
        .papi-input::placeholder { color: #94a3b8; }
        .papi-btn {
            width: 100%;
            padding: 0.9rem;
            background: #2563eb;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background .2s;
            font-family: inherit;
        }
        .papi-btn:hover { background: #1d4ed8; }
    </style>
</head>
<body style="background:#dbeafe; min-height:100vh; display:flex; align-items:center; justify-content:center; padding:2rem 1rem;">

    <div style="background:#ffffff; border-radius:16px; box-shadow:0 4px 32px rgba(37,99,235,0.10); padding:2.5rem 2.25rem; width:100%; max-width:400px;">

        <!-- Logo -->
        <div style="text-align:center; margin-bottom:1.5rem;">
            <div style="display:inline-flex; align-items:center; gap:0.5rem; margin-bottom:0.75rem;">
                <div style="width:36px; height:36px; background:linear-gradient(135deg,#3b82f6,#1d4ed8); border-radius:10px; display:flex; align-items:center; justify-content:center;">
                    <svg width="20" height="20" fill="none" stroke="white" stroke-width="2.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/>
                    </svg>
                </div>
                <span style="font-size:1.5rem; font-weight:800; color:#1e3a8a; letter-spacing:-0.5px;">Tiktek</span>
            </div>
            <p style="font-size:0.9rem; color:#64748b; margin:0;">Veuillez vous connecter.</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div style="background:#fef2f2; border:1px solid #fecaca; border-radius:8px; padding:0.75rem 1rem; margin-bottom:1rem; font-size:0.83rem; color:#dc2626;">
                <div asp-validation-summary="All" class="list-none"></div>
            </div>
        }

        <form method="post" style="display:flex; flex-direction:column; gap:0.75rem;">

            <div>
                <input asp-for="Input.Email" class="papi-input" placeholder="Identifiant *" autocomplete="username" />
                <span asp-validation-for="Input.Email" style="font-size:0.75rem; color:#dc2626; margin-top:2px; display:block;"></span>
            </div>

            <div style="position:relative;">
                <input asp-for="Input.Password" type="password" id="passwordInput" class="papi-input" placeholder="Mot de passe *" style="padding-right:2.75rem;" autocomplete="current-password" value="Admin123!" />
                <button type="button" onclick="togglePassword()" tabindex="-1"
                        style="position:absolute; right:12px; top:50%; transform:translateY(-50%); background:none; border:none; color:#94a3b8; cursor:pointer; padding:0; line-height:1; font-size:1.1rem;">
                    <svg id="eyeIcon" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                </button>
                <span asp-validation-for="Input.Password" style="font-size:0.75rem; color:#dc2626; margin-top:2px; display:block;"></span>
            </div>

            <div style="text-align:right; margin-top:-0.25rem;">
                <a href="#" style="font-size:0.83rem; color:#2563eb; text-decoration:none; font-weight:500;">Mot de passe oublié ?</a>
            </div>

            <button type="submit" class="papi-btn" style="margin-top:0.25rem;">Se connecter</button>

        </form>

        <p style="text-align:center; margin-top:1.25rem; font-size:0.85rem; color:#64748b;">
            Pas encore inscrit ?
            <a href="#" style="color:#2563eb; font-weight:600; text-decoration:none;">S'inscrire</a>
        </p>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js" defer></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js" defer></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js" defer></script>
    <script>
        function togglePassword() {
            const input = document.getElementById('passwordInput');
            const icon  = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>';
            } else {
                input.type = 'password';
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>';
            }
        }
    </script>
</body>
</html>
