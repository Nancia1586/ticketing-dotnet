@page
@model IndexModel
@{
    ViewData["Title"] = "Tableau de Bord";
}

<div class="space-y-6">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Tableau de Bord</h1>
            <p class="text-gray-500">Aperçu global de votre activité de billetterie.</p>
        </div>
        <div class="text-sm font-medium text-blue-600 bg-blue-50 px-3 py-1 rounded-full border border-blue-100">
            @DateTime.Now.ToString("dd MMMM yyyy")
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Total Tickets -->
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-blue-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 012-2h10a2 2 0 012 2v14a2 2 0 01-2 2H7a2 2 0 01-2-2V5z" />
                    </svg>
                </div>
                <span class="text-xs font-semibold text-green-600 bg-green-50 px-2 py-1 rounded-lg">Global</span>
            </div>
            <p class="text-sm font-medium text-gray-500">Billets Vendus</p>
            <h3 class="text-2xl font-bold text-gray-900">@Model.TotalTicketsSold</h3>
        </div>

        <!-- Total Revenue -->
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center text-emerald-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <span class="text-xs font-semibold text-blue-600 bg-blue-50 px-2 py-1 rounded-lg">Revenu</span>
            </div>
            <p class="text-sm font-medium text-gray-500">Chiffre d'Affaires</p>
            <h3 class="text-2xl font-bold text-gray-900">@Model.TotalRevenue.ToString("N2") Ar</h3>
        </div>

        <!-- Total Reservations -->
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center text-purple-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                    </svg>
                </div>
                <span class="text-xs font-semibold text-purple-600 bg-purple-50 px-2 py-1 rounded-lg">Total</span>
            </div>
            <p class="text-sm font-medium text-gray-500">Commandes Totales</p>
            <h3 class="text-2xl font-bold text-gray-900">@Model.TotalReservations</h3>
        </div>

        <!-- Events in Selling -->
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 bg-orange-50 rounded-xl flex items-center justify-center text-orange-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                </div>
                <span class="text-xs font-semibold text-orange-600 bg-orange-50 px-2 py-1 rounded-lg">En Vente</span>
            </div>
            <p class="text-sm font-medium text-gray-500">Événements Actifs</p>
            <h3 class="text-2xl font-bold text-gray-900">@Model.EventsSellingCount</h3>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Event Status Breakdown -->
        <div class="lg:col-span-1 bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
            <h3 class="text-lg font-bold text-gray-900 mb-6">Statut des Événements</h3>
            <div class="space-y-4">
                <div class="flex items-center justify-between p-4 bg-green-50 rounded-xl border border-green-100">
                    <div class="flex items-center space-x-3">
                        <div class="w-2 h-2 bg-green-500 rounded-full"></div>
                        <span class="text-sm font-semibold text-green-900">En cours de vente</span>
                    </div>
                    <span class="text-lg font-bold text-green-600">@Model.EventsSellingCount</span>
                </div>
                <div class="flex items-center justify-between p-4 bg-amber-50 rounded-xl border border-amber-100">
                    <div class="flex items-center space-x-3">
                        <div class="w-2 h-2 bg-amber-500 rounded-full"></div>
                        <span class="text-sm font-semibold text-amber-900">En attente</span>
                    </div>
                    <span class="text-lg font-bold text-amber-600">@Model.EventsPendingCount</span>
                </div>
                <div class="flex items-center justify-between p-4 bg-gray-50 rounded-xl border border-gray-100">
                    <div class="flex items-center space-x-3">
                        <div class="w-2 h-2 bg-gray-500 rounded-full"></div>
                        <span class="text-sm font-semibold text-gray-900">Terminés</span>
                    </div>
                    <span class="text-lg font-bold text-gray-600">@Model.EventsFinishedCount</span>
                </div>
            </div>

            <div class="mt-8">
                <h4 class="text-sm font-bold text-gray-700 mb-4 uppercase tracking-wider">Répartition par catégorie</h4>
                <div class="relative h-64">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Top Selling Events -->
        <div class="lg:col-span-2 bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-lg font-bold text-gray-900">Top des Événements (Billets Vendus)</h3>
                <a asp-page="/Events/Index" class="text-sm font-medium text-blue-600 hover:underline">Voir tout</a>
            </div>
            
            @if (Model.TopEvents.Any())
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left text-gray-500">
                        <thead class="text-xs text-gray-700 uppercase bg-gray-50 rounded-lg">
                            <tr>
                                <th class="px-4 py-3">Événement</th>
                                <th class="px-4 py-3 text-center">Billets Vendus</th>
                                <th class="px-4 py-3 text-right">Revenu HT</th>
                                <th class="px-4 py-3 text-right">Performance</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @foreach (var evt in Model.TopEvents)
                            {
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="px-4 py-4 font-semibold text-gray-900">@evt.Name</td>
                                    <td class="px-4 py-4 text-center">@evt.TicketsSold</td>
                                    <td class="px-4 py-4 text-right font-medium text-gray-900">@evt.Revenue.ToString("C")</td>
                                    <td class="px-4 py-4">
                                        <div class="w-full bg-gray-100 rounded-full h-2 max-w-[100px] ml-auto">
                                            @{
                                                var maxSold = Model.TopEvents.Max(e => e.TicketsSold);
                                                var percentage = maxSold > 0 ? (evt.TicketsSold * 100 / maxSold) : 0;
                                            }
                                            <div class="bg-blue-600 h-2 rounded-full" style="width: @percentage%"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                <div class="mt-8 h-64">
                    <canvas id="topEventsChart"></canvas>
                </div>
            }
            else
            {
                <div class="flex flex-col items-center justify-center py-12 text-gray-400">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>
                    <p>Aucune donnée de vente pour le moment.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Category Chart
            const categoryCtx = document.getElementById('categoryChart').getContext('2d');
            const categoryData = @Html.Raw(Json.Serialize(Model.CategoryStatsList));
            
            new Chart(categoryCtx, {
                type: 'doughnut',
                data: {
                    labels: categoryData.map(c => c.name),
                    datasets: [{
                        data: categoryData.map(c => c.count),
                        backgroundColor: [
                            '#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#ec4899'
                        ],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                usePointStyle: true,
                                padding: 20,
                                font: { size: 11 }
                            }
                        }
                    },
                    cutout: '70%'
                }
            });

            // Top Events Chart
            const topEventsCtx = document.getElementById('topEventsChart')?.getContext('2d');
            if (topEventsCtx) {
                const topEventsData = @Html.Raw(Json.Serialize(Model.TopEvents));
                
                new Chart(topEventsCtx, {
                    type: 'bar',
                    data: {
                        labels: topEventsData.map(e => e.name),
                        datasets: [{
                            label: 'Billets Vendus',
                            data: topEventsData.map(e => e.ticketsSold),
                            backgroundColor: 'rgba(59, 130, 246, 0.8)',
                            borderRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: '#f3f4f6' }
                            },
                            x: {
                                grid: { display: false }
                            }
                        }
                    }
                });
            }
        });
    </script>
}
