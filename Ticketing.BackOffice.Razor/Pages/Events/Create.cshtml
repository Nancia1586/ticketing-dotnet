@page
@model Ticketing.BackOffice.Razor.Pages.Events.CreateModel

@{
    ViewData["Title"] = "Créer un Événement";
}

<h1 class="text-3xl font-bold mb-6 text-gray-800">Créer un nouvel événement</h1>

<div class="max-w-xl bg-white p-8 rounded-lg shadow-xl">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-red-600 mb-4"></div>

        <div class="mb-4">
            <label asp-for="Event.Name" class="block text-sm font-medium text-gray-700">Nom de l'événement</label>
            <input asp-for="Event.Name" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2 border" />
            <span asp-validation-for="Event.Name" class="text-red-600 text-xs mt-1"></span>
        </div>
        
        <div class="mb-4">
            <label asp-for="Event.Location" class="block text-sm font-medium text-gray-700">Lieu</label>
            <input asp-for="Event.Location" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2 border" />
            <span asp-validation-for="Event.Location" class="text-red-600 text-xs mt-1"></span>
        </div>
        
        <div class="mb-4">
            <label asp-for="Event.Date" class="block text-sm font-medium text-gray-700">Date et heure</label>
            <input asp-for="Event.Date" type="datetime-local" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2 border" />
            <span asp-validation-for="Event.Date" class="text-red-600 text-xs mt-1"></span>
        </div>
        
        <div class="mb-4">
            <label asp-for="Event.PosterUrl" class="block text-sm font-medium text-gray-700">URL de l'affiche (facultatif)</label>
            <input asp-for="Event.PosterUrl" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2 border" />
            <span asp-validation-for="Event.PosterUrl" class="text-red-600 text-xs mt-1"></span>
        </div>
        
        <div class="mb-4 flex items-center">
            <input asp-for="Event.IsActive" type="checkbox" class="h-4 w-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500" />
            <label asp-for="Event.IsActive" class="ml-2 block text-sm font-medium text-gray-700">Actif (Visible sur le Front-Office)</label>
        </div>

        <div class="flex space-x-4">
            <button type="submit" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                Créer
            </button>
            <a asp-page="Index" class="py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                Annuler
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}