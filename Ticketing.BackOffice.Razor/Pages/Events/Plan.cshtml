@page "{id:int?}"
@model Ticketing.BackOffice.Razor.Pages.Events.PlanModel

@{
    ViewData["Title"] = $"Plan de Salle Structuré pour {Model.Event.Name}";
}

<link rel="stylesheet" href="~/css/events/plan.css" asp-append-version="true" />

<div class="max-w-7xl mx-auto bg-white rounded-lg shadow-xl p-10">
    <h1 class="text-2xl font-extrabold text-gray-900 mb-2">Configuration du plan par type de ticket</h1>
    <div class="flex flex-col gap-2 md:flex-row md:gap-0 md:items-center md:justify-between py-4 text-blue-600 mb-4">
        <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-tag-icon lucide-tag"><path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/></svg>
            @Model.Event.Name
        </span>
        <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin-icon lucide-map-pin"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
            @Model.Event.Venue?.Name
        </span>
        <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar-days-icon lucide-calendar-days"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/><path d="M16 18h.01"/></svg>
            @Model.Event.Date.ToString("dd/MM/yyyy à HH:mm")
        </span>
    </div>

    <form method="post" id="plan-form" class="space-y-6">
        @* <div asp-validation-summary="All" class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4"></div> *@
        <input type="hidden" name="eventId" value="@Model.Event.Id" />

        <div class="p-6 bg-gray-50 rounded-lg border">
            <div class="flex flex-col gap-4">
                <h3 class="text-xl font-semibold text-gray-700">Lieu & Dimensions</h3>
                <p class="text-sm text-gray-500">
                    Le plan est défini par le lieu associé à l'événement.
                </p>
            </div>
            <div class="flex flex-col gap-4 md:flex-row md:gap-8 md:items-center">
                <input type="hidden" id="total-rows-input" value="@Model.TotalRows" />
                <input type="hidden" id="total-columns-input" value="@Model.TotalColumns" />
                <input type="hidden" id="venue-layout-json" value="@Model.Event.Venue?.LayoutJson" />
            </div>
        </div>

        <div class="p-6 bg-white rounded-lg border shadow-md">
            <div class="flex flex-col gap-4 mb-4 border-b p-2">
                <h3 class="text-xl font-semibold text-gray-700">Types de ticket & Assignation des sièges</h3>
                <p class="text-sm text-gray-500">
                    Cliquez sur un type de ticket pour l'activer, puis **cliquez ou cliquez-glissez** sur les sièges de la grille pour les assigner/désassigner.
                </p>
            </div>
            
            <div id="ticket-types-container" class="space-y-4">
                @if (Model.TicketTypePlans.Any())
                {
                    for (int i = 0; i < Model.TicketTypePlans.Count; i++)
                    {
                        var plan = Model.TicketTypePlans[i];
                        <div class="ticket-type-row bg-gray-50 p-4 rounded-lg shadow-sm grid grid-cols-12 gap-4 items-center border-2 border-transparent cursor-pointer" 
                             data-index="@i" 
                             data-ticket-type-id="@plan.TicketTypeId"
                             data-color="@plan.Color">
                            
                            <input type="hidden" name="TicketTypePlans[@i].TicketTypeId" value="@plan.TicketTypeId" />
                            <input type="hidden" name="TicketTypePlans[@i].Color" value="@plan.Color" class="type-color-value" />
                            <input type="hidden" name="TicketTypePlans[@i].SelectedSeatsJson" value="@plan.SelectedSeatsJson" class="selected-seats-json" />

                            <div class="col-span-3">
                                <label class="block text-xs font-medium text-gray-500">Nom / Couleur</label>
                                <div class="flex items-center space-x-2 mt-2">
                                    <input name="TicketTypePlans[@i].Name" value="@plan.Name" placeholder="Ex: VIP" class="input-field type-name-input" required />
                                    <input type="color" class="color-picker-input" value="@plan.Color" data-index="@i"/>
                                </div>
                            </div>
                            
                            <div class="col-span-3">
                                <label class="block text-xs font-medium text-gray-500">Prix (Ar)</label>
                                <input name="TicketTypePlans[@i].Price" value="@plan.Price" type="number" step="0.01" min="0" class="input-field mt-2 type-price-input" required />
                            </div>
                            
                            <div class="col-span-2">
                                <label class="block text-xs font-medium text-gray-500">Placement</label>
                                <select name="TicketTypePlans[@i].IsReservedSeating" class="select-field mt-2 is-reserved-seating" data-original-value="@plan.IsReservedSeating.ToString().ToLower()">
                                    <option value="true" selected="@(plan.IsReservedSeating)">Réservé</option> 
                                    <option value="false" selected="@(!plan.IsReservedSeating)">Libre</option>
                                </select>
                            </div>
                            
                            <div class="col-span-3 text-sm text-gray-600 flex items-center space-x-2 mt-5 ml-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-blue-500 lucide lucide-lock-keyhole-icon lucide-lock-keyhole lock-icon-container"><circle cx="12" cy="16" r="1"/><rect x="3" y="10" width="18" height="12" rx="2"/><path d="M7 10V7a5 5 0 0 1 10 0v3"/></svg>
                                <span class="seat-count-display">0 sièges assignés</span>
                            </div>

                            <div class="col-span-1 flex justify-end">
                                <button type="button" class="remove-type-btn text-red-500 hover:text-red-700 font-bold py-1 px-2 rounded transition duration-150">
                                    &times;
                                </button>
                            </div>
                        </div>
                    }
                }
                <p id="no-types-message" class="text-gray-500 italic text-sm mb-2 @(Model.TicketTypePlans.Any() ? "hidden" : "")">
                    Cliquez sur "Ajouter un type de ticket" pour commencer l'assignation.
                </p>
            </div>

            <button type="button" id="add-type-btn" class="btn-primary text-sm rounded-md py-2 px-4">
                Ajouter un type de ticket
            </button>
        </div>
        
        <div class="p-6 bg-gray-100 rounded-lg border">
            <h3 class="text-xl font-semibold text-gray-700 mb-4">Visualisation du plan interactif</h3>
            
            <div id="active-selection-info" class="mb-4 p-3 bg-blue-100 text-blue-800 rounded-lg hidden space-y-2">
                <p class="font-semibold">Mode sélection actif : <span id="active-type-name"></span></p>
                <p class="text-sm">Cliquez-glissez sur les sièges pour assigner ou désassigner une zone. 
                @* <span class="ml-4 font-mono bg-white px-2 py-1 rounded shadow-sm text-xs">
                    Position: <span id="row-letter-info">-</span><span id="col-number-info">-</span>
                </span> *@
                </p>
            </div>
            
            <div id="plan-grid-wrapper" class="relative text-center">
                <div id="plan-grid" style="grid-template-columns: repeat(@Model.TotalColumns, 1fr); grid-template-rows: repeat(@Model.TotalRows, 1fr);">
                    <!-- Les sièges seront générés ici par JS -->
                </div>
                <p class="mt-4 text-sm text-gray-600">
                    Chaque cellule représente une place. La couleur est basée sur le type de ticket assigné.
                </p>
                <div class="mt-4 flex flex-wrap justify-center space-x-4" id="legend-container">
                    <!-- Légende sera générée ici -->
                </div>
            </div>
        </div>

        <div class="flex justify-end items-center mt-8 pt-6 border-t border-gray-200">
            <div class="space-x-4">
                <a asp-page="./Edit" asp-route-id="@Model.Event.Id" class="inline-flex justify-center items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50">
                    Retour à l'événement
                </a>
                <button type="submit" class="btn-primary text-sm rounded-md py-2 px-4">
                    Sauvegarder Plan & Types
                </button>
            </div>
        </div>
    </form>
</div>

<script id="type-template" type="text/html">
    <div class="ticket-type-row bg-gray-50 p-4 rounded-lg shadow-sm grid grid-cols-12 gap-4 items-center border-2 border-transparent cursor-pointer" 
         data-index="__INDEX__" 
         data-ticket-type-id="0"
         data-color="#3b82f6">
        
        <input type="hidden" name="TicketTypePlans[__INDEX__].TicketTypeId" value="0" /> 
        <input type="hidden" name="TicketTypePlans[__INDEX__].Color" value="#3b82f6" class="type-color-value" />
        <input type="hidden" name="TicketTypePlans[__INDEX__].SelectedSeatsJson" value="[]" class="selected-seats-json" />

        <div class="col-span-3">
            <label class="block text-xs font-medium text-gray-500">Nom / Couleur</label>
            <div class="flex items-center space-x-2 mt-2">
                <input name="TicketTypePlans[__INDEX__].Name" value="Nouveau Type" placeholder="Ex: Standard" class="input-field type-name-input" required />
                <input type="color" class="color-picker-input" value="#3b82f6" data-index="__INDEX__"/>
            </div>
        </div>
        
        <div class="col-span-3">
            <label class="block text-xs font-medium text-gray-500">Prix (Ar)</label>
            <input name="TicketTypePlans[__INDEX__].Price" value="50.00" type="number" step="0.01" min="0" class="input-field mt-2 type-price-input" required />
        </div>
        
        <div class="col-span-2">
            <label class="block text-xs font-medium text-gray-500">Placement</label>
            <select name="TicketTypePlans[__INDEX__].IsReservedSeating" class="select-field mt-2 is-reserved-seating" data-original-value="true">
                <option value="true" selected>Réservé</option> 
                <option value="false">Libre</option>
            </select>
        </div>

        <div class="col-span-3 text-sm text-gray-600 flex items-center space-x-2 mt-5 ml-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-blue-500 lucide lucide-lock-keyhole-icon lucide-lock-keyhole lock-icon-container"><circle cx="12" cy="16" r="1"/><rect x="3" y="10" width="18" height="12" rx="2"/><path d="M7 10V7a5 5 0 0 1 10 0v3"/></svg>
            <span class="seat-count-display">0 sièges assignés</span>
        </div>

        <div class="col-span-1 flex justify-end mt-5">
            <button type="button" class="remove-type-btn text-red-500 hover:text-red-700 font-bold py-1 px-2 rounded transition duration-150">
                &times;
            </button>
        </div>
    </div>
</script>

@section Scripts {
    <script src="~/js/events/plan.js" asp-append-version="true"></script>
}