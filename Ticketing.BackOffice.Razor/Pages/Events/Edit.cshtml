@page
@model Ticketing.BackOffice.Razor.Pages.Events.EditModel

@{
    ViewData["Title"] = "Modifier un Événement";
}

<div class="overflow-x-auto bg-white rounded-lg shadow-xl max-w-7xl p-10">
    <h1 class="text-2xl font-extrabold mb-8 text-gray-900">Modifier l'Événement: @Model.Event.Name</h1>
        
        <form method="post">
            <input type="hidden" asp-for="Event.Id" />
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                <div>
                    <label asp-for="Event.Name" class="block text-sm font-medium text-gray-700 mb-2">Nom de l'événement</label>
                    <input asp-for="Event.Name" class="w-full h-10 px-2 border border-gray-200 rounded-md focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" />
                    <span asp-validation-for="Event.Name" class="text-xs text-red-600 mt-1 block"></span>
                </div>

                <div></div>

                <div class="col-span-2">
                    <label asp-for="Event.Description" class="block text-sm font-medium text-gray-700 mb-2">Description de l'événement</label>
                    <textarea asp-for="Event.Description" class="w-full h-32 p-2 border border-gray-200 rounded-md focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"></textarea>
                    <span asp-validation-for="Event.Description" class="text-xs text-red-600 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Event.VenueId" class="block text-sm font-medium text-gray-700 mb-2">Lieu</label>
                    <select asp-for="Event.VenueId" asp-items="Model.VenueSelectList" class="w-full h-10 px-2 border border-gray-200 rounded-md focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500">
                        <option value="">-- Sélectionner un lieu --</option>
                    </select>
                    <span asp-validation-for="Event.VenueId" class="text-xs text-red-600 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Event.Date" class="block text-sm font-medium text-gray-700 mb-2">Date et Heure</label>
                    <input asp-for="Event.Date" value="@Model.Event.Date.ToString("yyyy-MM-ddTHH:mm")" type="datetime-local" class="w-full h-10 px-2 border border-gray-200 rounded-md focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" />
                    <span asp-validation-for="Event.Date" class="text-xs text-red-600 mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Event.CategoryId" class="block text-sm font-medium text-gray-700 mb-2">Catégorie</label>
                    <select asp-for="Event.CategoryId" asp-items="Model.CategorySelectList" class="w-full h-10 px-2 border border-gray-200 rounded-md focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500">
                        <option value="">-- Sélectionner une catégorie --</option>
                    </select>
                    <span asp-validation-for="Event.CategoryId" class="text-xs text-red-600 mt-1 block"></span>
                </div>
            </div>

            <h2 class="text-lg font-semibold text-gray-700 border-t pt-6 mt-6 mb-4">Affiche de l'Événement</h2>

            <div class="flex gap-6 mb-8">
                <div class="flex flex-col items-start">
                    <div id="image-preview-container" class="w-56 h-64 bg-gray-100 rounded-lg border-2 border-dashed border-gray-300 flex items-center justify-center overflow-hidden">
                        <img id="image-preview" src="@Model.Event.PosterUrl" 
                             alt="Aperçu de l'affiche" 
                             class="w-full h-full object-cover @(string.IsNullOrEmpty(Model.Event.PosterUrl) ? "hidden" : "")">
                        
                        <span id="preview-placeholder" class="text-gray-500 text-sm @(!string.IsNullOrEmpty(Model.Event.PosterUrl) ? "hidden" : "")">
                            Aucune image sélectionnée
                        </span>
                    </div>
                </div>

                <div class="mt-4 md:mt-0">
                    <input type="file" id="poster-upload" accept="image/*" class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-blue-500"/>
                    
                    <input type="hidden" asp-for="Event.PosterBase64" id="poster-base64-input" />
                    
                    <input type="hidden" asp-for="Event.PosterUrl" /> 

                    <div class="flex flex-col gap-2 mt-4 text-sm text-gray-500">
                        <p>Formats acceptés : JPG, PNG</p>
                        <p>Taille maximale recommandée : 1MB</p>
                        <p>Laissez vide pour conserver l'image actuelle.</p>
                    </div>
                </div>
            </div>

            <div class="mb-4 flex items-center">
                <input asp-for="Event.IsActive" type="checkbox" class="h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
                <label asp-for="Event.IsActive" class="ml-2 block text-sm font-medium text-gray-700">Actif (Visible sur l'application)</label>
            </div>


            <div class="flex justify-end space-x-4 pt-8 mt-8 border-t">
                <a asp-page="./Index" class="inline-flex justify-center items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    Annuler
                </a>
                <button type="submit" class="inline-flex justify-center items-center px-6 py-3 border border-transparent text-sm font-medium rounded-lg shadow-sm btn-primary">
                    Sauvegarder les modifications
                </button>
            </div>
        </form>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const fileInput = document.getElementById('poster-upload');
            const previewImg = document.getElementById('image-preview');
            const placeholderSpan = document.getElementById('preview-placeholder');
            const base64Input = document.getElementById('poster-base64-input');

            fileInput.addEventListener('change', function () {
                const file = this.files[0];

                if (file) {
                    const reader = new FileReader();

                    reader.onload = function (e) {
                        previewImg.src = e.target.result;
                        previewImg.classList.remove('hidden');
                        placeholderSpan.classList.add('hidden');
                        
                        base64Input.value = e.target.result; 
                    };

                    reader.readAsDataURL(file);
                } else {
                    const existingUrl = previewImg.dataset.existingUrl;

                    if (previewImg.src && previewImg.src !== window.location.href) {
                        previewImg.classList.remove('hidden');
                        placeholderSpan.classList.add('hidden');
                        base64Input.value = "";
                    } else {
                        previewImg.src = "";
                        previewImg.classList.add('hidden');
                        placeholderSpan.classList.remove('hidden');
                        base64Input.value = "";
                    }
                }
            });
        });
    </script>
}