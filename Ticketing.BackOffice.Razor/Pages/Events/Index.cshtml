@page
@model Ticketing.BackOffice.Razor.Pages.Events.IndexModel
@{
    ViewData["Title"] = "Événements";
}

<style>
.ptbl{width:100%;border-collapse:collapse}
.ptbl th{text-align:left;font-size:.75rem;font-weight:600;color:#6b7280;padding:.55rem 1rem;border-bottom:1px solid #e5e7eb;background:#f9fafb;white-space:nowrap}
.ptbl td{font-size:.85rem;color:#111827;padding:.6rem 1rem;border-bottom:1px solid #f3f4f6}
.ptbl tbody tr:hover td{background:#eff6ff;cursor:pointer}
.ptbl tbody tr:last-child td{border-bottom:none}
</style>

<div class="flex items-center justify-between mb-4">
    <h1 class="text-xl font-bold text-gray-800">Événements</h1>
    <a asp-page="Create" class="px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition-colors">
        Nouveau
    </a>
</div>

<!-- Search -->
<div class="bg-white border border-gray-200 rounded-lg mb-3 overflow-hidden">
    <div class="px-4 py-2.5 text-sm font-semibold text-gray-700 flex justify-between items-center cursor-pointer" onclick="toggleSearch()">
        <span>Recherche</span>
        <svg id="sc" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="transition:transform .2s">
            <path d="m18 15-6-6-6 6"/>
        </svg>
    </div>
    <div id="sb" class="px-4 py-3 border-t border-gray-100">
        <form method="get" class="flex flex-wrap gap-2 items-center">
            <input type="text" name="searchTerm" value="@Model.SearchTerm" placeholder="Mots clés"
                   class="border border-gray-200 rounded-lg px-3 py-2 text-sm outline-none focus:border-blue-400 min-w-[200px]" />
            <button type="submit" class="px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700">Rechercher</button>
            <a asp-page="Index" class="px-4 py-2 border border-gray-300 text-gray-600 text-sm font-semibold rounded-lg hover:bg-gray-50">Réinitialiser</a>
        </form>
    </div>
</div>

<!-- Table -->
<div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <div class="px-4 py-2 border-b border-gray-100">
        <span class="text-xs text-gray-400">@Model.TotalCount résultat(s)</span>
    </div>
    <div class="overflow-x-auto">
        <table class="ptbl">
            <thead>
                <tr>
                    <th style="width:44px">#</th>
                    <th style="width:48px" class="hidden sm:table-cell"></th>
                    <th>Nom</th>
                    <th class="hidden sm:table-cell">Catégorie</th>
                    <th class="hidden md:table-cell">Lieu</th>
                    <th class="hidden lg:table-cell">Date</th>
                    <th>Statut</th>
                </tr>
            </thead>
            <tbody>
                @{ int idx = (Model.CurrentPage - 1) * 10 + 1; }
                @foreach (var e in Model.Events)
                {
                    <tr onclick="location.href='@Url.Page("Edit", new { id = e.Id })'">
                        <td class="text-gray-400 text-xs">@idx</td>
                        <td class="hidden sm:table-cell" style="padding:0.4rem 0.5rem">
                            @if (!string.IsNullOrEmpty(e.PosterUrl))
                            {
                                <img src="@e.PosterUrl" alt="" style="width:36px;height:36px;border-radius:50%;object-fit:cover;border:1px solid #e5e7eb" />
                            }
                            else
                            {
                                <div style="width:36px;height:36px;border-radius:50%;background:#dbeafe;display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;color:#2563eb;border:1px solid #bfdbfe">
                                    @(e.Name.Length > 0 ? e.Name[0].ToString().ToUpper() : "?")
                                </div>
                            }
                        </td>
                        <td class="font-medium">@e.Name</td>
                        <td class="hidden sm:table-cell text-gray-500 text-xs">@(e.Category?.Name ?? "—")</td>
                        <td class="hidden md:table-cell text-gray-500 text-xs">@(e.Venue?.Name ?? "—")</td>
                        <td class="hidden lg:table-cell text-gray-500 text-xs">@e.Date.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (!e.IsSubmitted)
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-700">
                                    <span class="w-1.5 h-1.5 rounded-full bg-amber-400 inline-block"></span>Brouillon
                                </span>
                            }
                            else if (e.IsActive)
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700">
                                    <span class="w-1.5 h-1.5 rounded-full bg-green-500 inline-block"></span>Actif
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
                                    <span class="w-1.5 h-1.5 rounded-full bg-gray-400 inline-block"></span>Inactif
                                </span>
                            }
                        </td>
                    </tr>
                    idx++;
                }
                @if (!Model.Events.Any())
                {
                    <tr><td colspan="6" class="text-center text-gray-400 py-10 text-sm">Aucun événement trouvé</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="px-4 py-2.5 border-t border-gray-100 flex items-center justify-between text-xs text-gray-500">
            <span>Page @Model.CurrentPage / @Model.TotalPages</span>
            <div class="flex gap-1">
                @if (Model.HasPreviousPage)
                {
                    <a asp-page="Index" asp-route-page="@(Model.CurrentPage-1)" asp-route-searchTerm="@Model.SearchTerm"
                       class="px-2.5 py-1 border border-gray-200 rounded hover:bg-gray-50">‹</a>
                }
                @for (int p = Math.Max(1, Model.CurrentPage-2); p <= Math.Min(Model.TotalPages, Model.CurrentPage+2); p++)
                {
                    <a asp-page="Index" asp-route-page="@p" asp-route-searchTerm="@Model.SearchTerm"
                       class="px-2.5 py-1 border rounded @(p==Model.CurrentPage?"bg-blue-600 text-white border-blue-600":"border-gray-200 hover:bg-gray-50")">@p</a>
                }
                @if (Model.HasNextPage)
                {
                    <a asp-page="Index" asp-route-page="@(Model.CurrentPage+1)" asp-route-searchTerm="@Model.SearchTerm"
                       class="px-2.5 py-1 border border-gray-200 rounded hover:bg-gray-50">›</a>
                }
            </div>
        </div>
    }
</div>

<script>
function toggleSearch(){
    const b=document.getElementById('sb'),c=document.getElementById('sc');
    const h=b.style.display==='none';
    b.style.display=h?'':'none';
    c.style.transform=h?'':'rotate(180deg)';
}
</script>
