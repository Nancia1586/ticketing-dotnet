@page
@model Ticketing.BackOffice.Razor.Pages.Events.IndexModel

@{
    ViewData["Title"] = "Gestion des Événements";
}

<div class="overflow-x-auto bg-white rounded-lg shadow-xl max-w-7xl p-10">

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Liste des événements</h1>

        <a asp-page="Create" type="button" class="btn-primary rounded-md text-white box-border border border-transparent focus:ring-4 shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none">Ajouter un nouvel événement</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        @foreach (var item in Model.Events) {
            <div class="flex flex-col bg-neutral-primary-soft border border-default rounded-md shadow-xs md:flex-row md:max-w-xl md:flex-row md:max-w-xl">
                <div class="h-64 md:h-64 md:w-52 mb-4 md:mb-0 bg-gray-200 flex items-center justify-center overflow-hidden rounded-l-md">
                    @if (!string.IsNullOrEmpty(item.PosterUrl))
                    {
                        <img class="object-cover w-full h-full" src="@item.PosterUrl" alt="Poster de @item.Name">
                    }
                    else
                    {
                        <div class="w-full h-full bg-indigo-50 flex items-center justify-center">
                            <span class="text-sm text-indigo-400">Affiche non disponible</span>
                        </div>
                    }
                </div>
                <div class="flex flex-col gap-3 leading-normal p-4 w-full">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-4">
                            <h5 class="text-xl font-bold tracking-tight text-heading">@Html.DisplayFor(modelItem => item.Name)</h5>
                            <span class="flex items-center h-6 px-4 text-xs font-semibold rounded-md whitespace-nowrap
                                @(item.IsActive ? "bg-green-200 text-green-700" : "bg-red-200 text-red-700")">
                                @(item.IsActive ? "Actif" : "Inactif") 
                            </span>
                        </div>
                        <div>
                            <button data-popover-target="popover-click-@item.Id" data-popover-trigger="click" type="button" data-popover-placement="bottom" class="text-gray-600 border border-gray-200 p-0.5 rounded-md hover:bg-gray-50 transition">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-ellipsis-icon lucide-ellipsis"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>
                            </button>

                            <div data-popover id="popover-click-@item.Id" role="tooltip" class="absolute z-10 invisible inline-block w-48 text-sm text-gray-700 transition-opacity duration-300 bg-white border border-gray-200 rounded-md shadow-lg opacity-0">
                                
                                <a asp-page="./Edit" asp-route-id="@item.Id" class="block px-3 py-2 bg-white border-b border-gray-100 rounded-t-md hover:bg-gray-50 transition">
                                    <h3 class="flex items-center gap-2 font-medium text-gray-800 hover:text-blue-600">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-square-pen-icon lucide-square-pen"><path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.375 2.625a1 1 0 0 1 3 3l-9.013 9.014a2 2 0 0 1-.853.505l-2.873.84a.5.5 0 0 1-.62-.62l.84-2.873a2 2 0 0 1 .506-.852z"/></svg>
                                        Modifier
                                    </h3>
                                </a>

                                @{
                                    var actionLabel = item.IsActive ? "Désactiver" : "Activer";
                                    var actionHandler = "ToggleStatus";
                                    var actionMessage = item.IsActive 
                                        ? $"Êtes-vous sûr de vouloir désactiver l'événement '{item.Name}'? Il ne sera plus visible."
                                        : $"Êtes-vous sûr de vouloir activer l'événement '{item.Name}'?";
                                    var actionStatus = (!item.IsActive).ToString().ToLower();

                                    var actionIcon = item.IsActive ? "square-minus" : "square-check";
                                }
                                <button type="button" 
                                        class="action-button w-full text-left px-3 py-2 bg-white border-b border-gray-100 hover:bg-gray-50 transition"
                                        data-action-type="status"
                                        data-event-id="@item.Id"
                                        data-event-name="@item.Name"
                                        data-handler="@actionHandler"
                                        data-message="@actionMessage"
                                        data-status="@actionStatus"
                                        data-confirm-text="@actionLabel">

                                    <h3 class="flex items-center gap-2 font-medium text-gray-800 hover:text-blue-600">
                                        @if (item.IsActive)
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-square-minus">
                                                <rect width="18" height="18" x="3" y="3" rx="2" />
                                                <path d="M8 12h8" />
                                            </svg>
                                            @:Désactiver
                                        }
                                        else
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-square-check">
                                                <rect width="18" height="18" x="3" y="3" rx="2" />
                                                <path d="m9 12 2 2 4-4" />
                                            </svg>
                                            @:Activer
                                        }
                                    </h3>
                                </button>
                                
                                <button type="button" 
                                        class="action-button w-full text-left px-3 py-2 bg-white rounded-b-md hover:bg-red-50 transition"
                                        data-action-type="delete"
                                        data-event-id="@item.Id"
                                        data-event-name="@item.Name"
                                        data-handler="Delete"
                                        data-message="Êtes-vous sûr de vouloir supprimer définitivement l'événement '@item.Name'? Cette action est irréversible."
                                        data-confirm-text="Supprimer">

                                    <h3 class="flex items-center gap-2 font-medium text-red-600 hover:text-red-700">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trash2-icon lucide-trash-2"><path d="M10 11v6"/><path d="M14 11v6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                        Supprimer
                                    </h3>
                                </button>

                                <div data-popper-arrow></div>
                            </div>
                        </div>
                    </div>
                    <p class="text-gray-600">@Html.DisplayFor(modelItem => item.Description)</p>
                    <div class="flex flex-col items-start gap-2 text-gray-600">
                        <p class="flex items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin-icon lucide-map-pin"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>

                            @Html.DisplayFor(modelItem => item.Location)
                        </p>
                        <p class="flex items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar-clock-icon lucide-calendar-clock"><path d="M16 14v2.2l1.6 1"/><path d="M16 2v4"/><path d="M21 7.5V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h3.5"/><path d="M3 10h5"/><path d="M8 2v4"/><circle cx="16" cy="16" r="6"/></svg>
                            @item.Date.ToString("dd/MM/yyyy à HH:mm")
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div id="confirmation-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-gray-900 bg-opacity-50 transition-opacity duration-300">
    <div class="bg-white rounded-xl shadow-2xl p-6 w-full max-w-md m-4 transform transition-all duration-300 scale-95 opacity-0">
        <h3 id="modal-title" class="text-lg font-bold text-gray-900 mb-4">Confirmation de l'Action</h3>
        <p id="modal-message" class="text-gray-600 mb-6">
            Êtes-vous sûr de vouloir procéder à cette action ?
        </p>
        
        <form id="action-form" method="post" class="hidden">
            <input type="hidden" name="id" id="modal-event-id" />
            <input type="hidden" name="isActive" id="modal-is-active" value="false" />
        </form>

        <div class="flex justify-end space-x-3">
            <button id="cancel-button" type="button" class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition">
                Annuler
            </button>
            <button id="confirm-button" type="button" class="btn-primary px-4 py-2 text-sm font-medium rounded-lg ">
                Confirmer
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modal = document.getElementById('confirmation-modal');
            const modalDialog = modal.querySelector('div:first-child');
            const confirmButton = document.getElementById('confirm-button');
            const cancelButton = document.getElementById('cancel-button');
            const actionForm = document.getElementById('action-form');
            const modalTitle = document.getElementById('modal-title');
            const modalMessage = document.getElementById('modal-message');
            const modalEventId = document.getElementById('modal-event-id');
            const modalIsActive = document.getElementById('modal-is-active');

            function showModal() {
                modal.classList.remove('hidden', 'opacity-0');
                modal.classList.add('flex', 'opacity-100');
                modalDialog.classList.remove('scale-95', 'opacity-0');
                modalDialog.classList.add('scale-100', 'opacity-100');
            }

            function hideModal() {
                modalDialog.classList.remove('scale-100', 'opacity-100');
                modalDialog.classList.add('scale-95', 'opacity-0');
                setTimeout(() => {
                    modal.classList.remove('flex', 'opacity-100');
                    modal.classList.add('hidden', 'opacity-0');
                }, 300);
            }

            document.querySelectorAll('.action-button').forEach(button => {
                button.addEventListener('click', function (e) {
                    e.preventDefault();
                    
                    const eventId = this.dataset.eventId;
                    const eventName = this.dataset.eventName;
                    const handler = this.dataset.handler;
                    const message = this.dataset.message;
                    const status = this.dataset.status;
                    const confirmText = this.dataset.confirmText;
                    const actionType = this.dataset.actionType;

                    modalMessage.textContent = message;
                    confirmButton.textContent = confirmText;
                    
                    if (actionType === 'delete') {
                        modalTitle.textContent = "Suppression Définitive";
                        confirmButton.classList.remove('btn-primary', 'bg-green-600', 'hover:bg-green-700');
                        confirmButton.classList.add('bg-red-600', 'hover:bg-red-700', 'text-white', 'hover:text-white');
                    } else {
                        modalTitle.textContent = `${confirmText} l'événement`;
                        confirmButton.classList.remove('bg-red-600', 'hover:bg-red-700');
                        confirmButton.classList.add('btn-primary');
                    }

                    modalEventId.value = eventId;
                    modalIsActive.value = status || 'false';

                    actionForm.action = `?handler=${handler}`;

                    showModal();
                });
            });

            confirmButton.addEventListener('click', function () {
                actionForm.submit();
                hideModal();
            });

            cancelButton.addEventListener('click', hideModal);

            modal.addEventListener('click', function(e) {
                if (e.target === modal) {
                    hideModal();
                }
            });
        });
    </script>
}