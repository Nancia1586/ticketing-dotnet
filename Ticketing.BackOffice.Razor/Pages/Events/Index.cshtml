@page
@model Ticketing.BackOffice.Razor.Pages.Events.IndexModel

@{
    ViewData["Title"] = "Gestion des Événements";
}

<div class="overflow-x-auto bg-white rounded-lg shadow-xl max-w-7xl p-10">

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Liste des événements</h1>

        <a asp-page="Create" type="button" class="btn-primary text-white box-border border border-transparent focus:ring-4 shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none">Ajouter un nouvel événement</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        @foreach (var item in Model.Events) {
            <a href="#" class="flex flex-col bg-neutral-primary-soft border border-default rounded-md shadow-xs md:flex-row md:max-w-xl md:flex-row md:max-w-xl">
                <img class="object-cover w-full rounded-base h-64 md:h-64 md:w-52 mb-4 md:mb-0" src="@item.PosterUrl" alt="">
                <div class="flex flex-col gap-3 leading-normal p-4">
                    <div class="flex items-center gap-4">
                        <h5 class="text-xl font-bold tracking-tight text-heading">@Html.DisplayFor(modelItem => item.Name)</h5>
                        <span class="flex items-center h-6 px-4 text-xs font-semibold rounded-md whitespace-nowrap
                            @(item.IsActive ? "bg-green-200 text-green-700" : "bg-red-200 text-red-700")">
                            @(item.IsActive ? "Actif" : "Brouillon") 
                        </span>
                    </div>
                    <p class="text-gray-600">@Html.DisplayFor(modelItem => item.Description)</p>
                    <div class="flex flex-col items-start gap-2 text-gray-600">
                        <p class="flex items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin-icon lucide-map-pin"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>

                            @Html.DisplayFor(modelItem => item.Location)
                        </p>
                        <p class="flex items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar-clock-icon lucide-calendar-clock"><path d="M16 14v2.2l1.6 1"/><path d="M16 2v4"/><path d="M21 7.5V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h3.5"/><path d="M3 10h5"/><path d="M8 2v4"/><circle cx="16" cy="16" r="6"/></svg>
                            @item.Date.ToString("dd/MM/yyyy à HH:mm")
                        </p>
                    </div>
                </div>
            </a>
        }
    </div>
</div>