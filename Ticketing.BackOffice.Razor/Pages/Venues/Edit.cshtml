@page "{id:int?}"
@model Ticketing.BackOffice.Razor.Pages.Venues.EditModel
@{
    ViewData["Title"] = Model.Venue?.Id > 0 ? $"Lieu — {Model.Venue.Name}" : "Nouveau lieu";
    bool isNew = !(Model.Venue?.Id > 0);
}

<style>
.pf{position:relative;margin-bottom:0}
.pf>label{position:absolute;left:.75rem;top:.38rem;font-size:.67rem;font-weight:500;color:#9ca3af;pointer-events:none;z-index:1;font-family:inherit}
.pf input,.pf textarea{width:100%;border:1px solid #d1d5db;border-radius:6px;padding:1.25rem .75rem .38rem;font-size:.875rem;color:#111827;background:#fff;outline:none;transition:border-color .15s;font-family:inherit;box-sizing:border-box}
.pf input:focus{border-color:#3b82f6}
.pf input[readonly]{background:#fafafa;cursor:default}
.ftabs{display:flex;border-bottom:2px solid #e5e7eb;margin-bottom:0;padding:0 1rem;padding-top:.25rem}
.ftab{padding:.55rem 1.1rem;font-size:.85rem;font-weight:500;color:#6b7280;border-bottom:2.5px solid transparent;margin-bottom:-2px;text-decoration:none;white-space:nowrap;display:inline-block}
.ftab:hover{color:#374151}
.ftab.on{color:#2563eb;border-bottom-color:#2563eb;font-weight:600}
.fbar{position:sticky;bottom:0;background:#fff;border-top:1px solid #e5e7eb;padding:.75rem 1.5rem;display:flex;align-items:center;justify-content:space-between;z-index:10;margin-top:1.5rem}
</style>

<div class="flex items-center gap-2 text-sm text-gray-500 mb-3">
    <a asp-page="Index" class="hover:text-blue-600 transition-colors">Lieux</a>
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
    <span class="text-gray-800 font-medium">@(isNew ? "Nouveau" : Model.Venue?.Name)</span>
</div>

<div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <div class="ftabs">
        <span class="ftab on" onclick="showTab('general',this)">Général</span>
        <span class="ftab" onclick="showTab('plan',this)">Configuration du plan</span>
    </div>

    <form method="post" id="mainForm">
        <input type="hidden" asp-for="Venue.Id" />
        <input type="hidden" asp-for="Venue.LayoutJson" id="layoutJson" />

        <!-- Tab: Général -->
        <div id="tab_general" class="p-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <div class="pf lg:col-span-2">
                <label>Nom *</label>
                <input asp-for="Venue.Name" placeholder=" " readonly id="f_name" />
                <span asp-validation-for="Venue.Name" class="text-xs text-red-500 mt-0.5 block"></span>
            </div>
            <div class="pf">
                <label>Adresse</label>
                <input asp-for="Venue.Address" placeholder=" " readonly id="f_address" />
            </div>
            <div class="pf">
                <label>Lignes (rangées)</label>
                <input asp-for="Venue.TotalRows" type="number" min="0" placeholder=" " readonly id="f_rows" />
            </div>
            <div class="pf">
                <label>Colonnes</label>
                <input asp-for="Venue.TotalColumns" type="number" min="0" placeholder=" " readonly id="f_cols" />
            </div>
            <div class="flex items-end pb-1" id="genGridBtn" style="display:none!important">
                <button type="button" onclick="generateGrid()"
                        class="px-4 py-2 bg-gray-100 text-gray-700 text-sm font-semibold rounded-lg hover:bg-gray-200 border border-gray-200 w-full">
                    Générer la grille
                </button>
            </div>
        </div>

        <!-- Tab: Plan -->
        <div id="tab_plan" class="p-6" style="display:none">
            <p class="text-sm text-gray-500 mb-4">Configurez les zones de votre plan de salle. Sélectionnez des cellules puis assignez-leur un type.</p>
            <div id="grid-container" class="overflow-auto"></div>
            <div id="zone-modal" class="hidden fixed inset-0 bg-black/40 flex items-center justify-center z-50">
                <div class="bg-white rounded-xl shadow-xl p-6 w-80">
                    <h3 class="font-semibold text-gray-800 mb-4">Configurer la zone</h3>
                    <div class="flex flex-col gap-3">
                        <div>
                            <label class="text-xs text-gray-500 font-medium block mb-1">Type</label>
                            <select id="zoneType" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm outline-none focus:border-blue-400">
                                <option value="assignable">Assignable</option>
                                <option value="void">Vide / Passage</option>
                            </select>
                        </div>
                        <div>
                            <label class="text-xs text-gray-500 font-medium block mb-1">Étiquette (optionnel)</label>
                            <input type="text" id="zoneLabel" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm outline-none focus:border-blue-400" placeholder="Ex: Scène, Allée…" />
                        </div>
                    </div>
                    <div class="flex gap-2 justify-end mt-4">
                        <button type="button" onclick="closeZoneModal()" class="px-3 py-1.5 border border-gray-200 text-gray-600 text-sm rounded-lg hover:bg-gray-50">Annuler</button>
                        <button type="button" onclick="applyZone()" class="px-3 py-1.5 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700">Appliquer</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="fbar">
            <span class="text-xs text-gray-400">@(isNew ? "Nouveau lieu" : $"ID : {Model.Venue?.Id}")</span>
            <div id="barRead" class="flex gap-2">
                <button type="button" onclick="enableEdit()"
                        class="px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700">Modifier</button>
            </div>
            <div id="barEdit" class="flex gap-2" hidden>
                <button type="button" onclick="cancelEdit()"
                        class="px-4 py-2 border border-gray-300 text-gray-600 text-sm font-semibold rounded-lg hover:bg-gray-50">Annuler</button>
                <button type="submit"
                        class="px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700">Enregistrer</button>
            </div>
        </div>
    </form>
</div>

<script>
let editMode = false;
let selectedCells = [];
let currentLayout = (@Html.Raw(Model.Venue?.LayoutJson ?? "[]")).map(z => ({
    row: z.row ?? z.r,
    col: z.col ?? z.c,
    type: z.type,
    label: z.label
}));

function showTab(tab, el) {
    document.getElementById('tab_general').style.display = tab==='general' ? '' : 'none';
    document.getElementById('tab_plan').style.display = tab==='plan' ? '' : 'none';
    document.querySelectorAll('.ftab').forEach(t => t.classList.remove('on'));
    el.classList.add('on');
    if(tab==='plan') renderGrid();
}

function enableEdit() {
    editMode = true;
    ['f_name','f_address','f_rows','f_cols'].forEach(id => document.getElementById(id)?.removeAttribute('readonly'));
    document.getElementById('genGridBtn').style.removeProperty('display');
    document.getElementById('barRead').hidden = true;
    document.getElementById('barEdit').hidden = false;
}
function cancelEdit() { location.reload(); }

function generateGrid() {
    const rows = parseInt(document.getElementById('f_rows').value)||0;
    const cols = parseInt(document.getElementById('f_cols').value)||0;
    if(rows<1||cols<1) return;
    currentLayout = [];
    renderGrid();
    showTab('plan', document.querySelectorAll('.ftab')[1]);
}

function renderGrid() {
    const rows = parseInt(document.getElementById('f_rows').value)||0;
    const cols = parseInt(document.getElementById('f_cols').value)||0;
    const container = document.getElementById('grid-container');
    if(!rows||!cols){ container.innerHTML='<p class="text-sm text-gray-400">Définissez les dimensions dans l\'onglet Général puis cliquez sur Générer la grille.</p>'; return; }
    let html = '<div style="display:grid;grid-template-columns:repeat('+cols+',28px);gap:2px;padding:4px;">';
    for(let r=1;r<=rows;r++){
        for(let c=1;c<=cols;c++){
            const zone = currentLayout.find(z=>z.row===r&&z.col===c);
            const type = zone?.type||'assignable';
            const bg = type==='void'?'#ef5350':'#bfdbfe';
            html+=`<div data-r="${r}" data-c="${c}" onclick="cellClick(this)"
                style="width:28px;height:28px;background:${bg};border-radius:4px;cursor:${editMode?'pointer':'default'};font-size:9px;display:flex;align-items:center;justify-content:center;color:#ffffff"
                title="R${r}C${c}">${zone?.label||''}</div>`;
        }
    }
    html+='</div>';
    container.innerHTML=html;
}

function cellClick(el) {
    if(!editMode) return;
    el.style.outline=el.style.outline?'':'2px solid #2563eb';
    const r=parseInt(el.dataset.r),c=parseInt(el.dataset.c);
    const idx=selectedCells.findIndex(s=>s.r===r&&s.c===c);
    if(idx>=0) selectedCells.splice(idx,1); else selectedCells.push({r,c});
    if(selectedCells.length>0) openZoneModal();
}

function openZoneModal(){ document.getElementById('zone-modal').classList.remove('hidden'); }
function closeZoneModal(){ document.getElementById('zone-modal').classList.add('hidden'); selectedCells=[]; renderGrid(); }

function applyZone(){
    const type=document.getElementById('zoneType').value;
    const label=document.getElementById('zoneLabel').value;
    selectedCells.forEach(s=>{
        const idx=currentLayout.findIndex(z=>z.row===s.r&&z.col===s.c);
        if(idx>=0) currentLayout[idx]={...currentLayout[idx],type,label};
        else currentLayout.push({row:s.r,col:s.c,type,label});
    });
    document.getElementById('layoutJson').value=JSON.stringify(currentLayout);
    closeZoneModal();
}

@if(isNew){ <text>window.addEventListener('DOMContentLoaded',enableEdit);</text> }
</script>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
