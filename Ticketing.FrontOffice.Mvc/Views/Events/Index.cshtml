@model Ticketing.FrontOffice.Mvc.Models.EventListViewModel

@{
    ViewData["Title"] = "Events";
}

<div class="container my-5">
    <h1 class="text-center mb-5 display-4 fw-bold text-primary">Upcoming Events</h1>

    <!-- Search & Filter -->
    <div class="row justify-content-center mb-5">
        <div class="col-md-8">
            <form method="get" class="d-flex gap-2 p-4 bg-light rounded shadow-sm">
                <input type="text" name="searchTerm" class="form-control form-control-lg border-0" placeholder="Search events..." value="@Model.SearchTerm" />
                <input type="date" name="filterDate" class="form-control form-control-lg border-0" value="@Model.FilterDate?.ToString("yyyy-MM-dd")" />
                <button type="submit" class="btn btn-primary btn-lg px-4 fw-bold">Find</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-3">Clear</a>
            </form>
        </div>
    </div>

    <!-- Events Grid -->
    <div class="row g-4">
        @if (!Model.Events.Any())
        {
            <div class="col-12 text-center py-5">
                <h3 class="text-muted">No events found matching your criteria.</h3>
            </div>
        }
        else
        {
            @foreach (var item in Model.Events)
            {
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-lg hover-transform overflow-hidden">
                         @if(!string.IsNullOrEmpty(item.PosterUrl))
                        {
                             <img src="@item.PosterUrl" class="card-img-top" alt="@item.Name" style="height: 250px; object-fit: cover;">
                        }
                        else if (!string.IsNullOrEmpty(item.PosterBase64))
                        {
                            <img src="data:image/png;base64,@item.PosterBase64" class="card-img-top" alt="@item.Name" style="height: 250px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 250px;">
                                <span class="text-white fs-4">No Image</span>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold">@item.Name</h5>
                            <p class="card-text text-muted mb-2">
                                <i class="bi bi-calendar-event me-2"></i>@item.Date.ToString("f")
                            </p>
                            <p class="card-text text-muted mb-3">
                                <i class="bi bi-geo-alt me-2"></i>@item.Venue?.Name
                            </p>
                            <p class="card-text small mb-4">@item.Description</p>
                            
                            <div class="mt-auto">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary w-100 fw-bold py-2">
                                    Book Tickets
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    .hover-transform {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-transform:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important;
    }
</style>
