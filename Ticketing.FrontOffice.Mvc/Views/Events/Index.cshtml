@model Ticketing.FrontOffice.Mvc.Models.EventListViewModel

@{
    ViewData["Title"] = "Events";
}

<div class="container my-5">
    <!-- Page Header -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold mb-3">Discover Amazing Events</h1>
        <p class="text-secondary fs-5">Find and book tickets for the best events happening near you</p>
    </div>

    <!-- Search & Filter -->
    <div class="row justify-content-center mb-5">
        <div class="col-lg-10">
            <form method="get" class="card-custom p-4">
                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="search-wrapper">
                            <i class="bi bi-search search-icon"></i>
                            <input type="text" name="searchTerm" class="search-input" placeholder="Search events by name..." value="@Model.SearchTerm" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <input type="date" name="filterDate" class="form-control form-control-lg bg-card border-secondary text-white" value="@Model.FilterDate?.ToString("yyyy-MM-dd")" />
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12 d-flex gap-2 justify-content-end">
                        <button type="submit" class="btn-primary-custom">
                            <i class="bi bi-search me-2"></i>Search
                        </button>
                        <a asp-action="Index" class="btn-secondary-custom">
                            <i class="bi bi-x-circle me-2"></i>Clear
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Events Grid -->
    <div class="row g-4">
        @if (!Model.Events.Any())
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-calendar-x display-1 text-secondary mb-3"></i>
                <h3 class="text-secondary mb-2">No events found</h3>
                <p class="text-muted">Try adjusting your search criteria or check back later.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model.Events)
            {
                var bgImage = !string.IsNullOrEmpty(item.PosterUrl) 
                    ? item.PosterUrl 
                    : (!string.IsNullOrEmpty(item.PosterBase64) 
                        ? $"data:image/png;base64,{item.PosterBase64}" 
                        : "https://placehold.co/400x600/1a1a1a/FFF?text=" + Uri.EscapeDataString(item.Name));
                var minPrice = item.TicketTypes.Any() ? item.TicketTypes.Min(t => t.Price) : 0;
                
                <div class="col-md-6 col-lg-4 col-xl-3">
                    <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                        <div class="event-card fade-in">
                            <img src="@bgImage" alt="@item.Name" />
                            <div class="event-card-overlay">
                                <h3 class="event-card-title">@item.Name</h3>
                                <div class="event-card-meta">
                                    <div class="mb-2">
                                        <i class="bi bi-calendar-event me-2 text-accent-primary"></i>
                                        <span>@item.Date.ToString("MMM dd, yyyy")</span>
                                    </div>
                                    <div class="mb-2">
                                        <i class="bi bi-clock me-2 text-accent-primary"></i>
                                        <span>@item.Date.ToString("HH:mm")</span>
                                    </div>
                                    <div class="mb-2">
                                        <i class="bi bi-geo-alt me-2 text-accent-primary"></i>
                                        <span>@(item.Venue?.Name ?? "TBA")</span>
                                    </div>
                                </div>
                                <div class="event-card-cta">
                                    <span class="hero-carousel-price mb-3 d-inline-block">From @minPrice.ToString("N0") Ar</span>
                                    <button class="btn-primary-custom w-100">
                                        <i class="bi bi-ticket-perforated me-2"></i>Book Ticket
                                    </button>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        }
    </div>
</div>

<style>
    .event-card {
        height: 500px;
    }
    
    @@media (max-width: 768px) {
        .event-card {
            height: 400px;
        }
    }
</style>
