@model Ticketing.FrontOffice.Mvc.Models.EventListViewModel

@{
    ViewData["Title"] = "Événements";
}

<style>
    .events-page {
        background: linear-gradient(145deg, #dbeafe 0%, #bfdbfe 60%, #93c5fd 100%);
        min-height: calc(100vh - 72px);
        padding: 2.5rem 1.5rem;
    }

    /* ── Search bar ─────────────────────────────── */
    .search-bar {
        display: flex;
        align-items: center;
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(37, 99, 235, 0.1);
        overflow: hidden;
        border: 1.5px solid #e2e8f0;
    }

    .search-bar:focus-within {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
    }

    .search-bar-input {
        flex: 1;
        border: none;
        outline: none;
        padding: 0.875rem 1rem 0.875rem 2.75rem;
        font-size: 0.95rem;
        color: #1e293b;
        background: transparent;
        min-width: 0;
    }

    .search-bar-input::placeholder { color: #94a3b8; }

    .search-bar-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        font-size: 1rem;
        pointer-events: none;
    }

    .search-bar-divider {
        width: 1px;
        height: 28px;
        background: #e2e8f0;
        flex-shrink: 0;
    }

    .search-bar-date {
        border: none;
        outline: none;
        padding: 0.875rem 0.875rem;
        font-size: 0.875rem;
        color: #475569;
        background: transparent;
        width: 148px;
        flex-shrink: 0;
        cursor: pointer;
    }

    .search-bar-date::-webkit-calendar-picker-indicator { cursor: pointer; opacity: 0.5; }

    .search-bar-submit {
        background: #2563eb;
        color: #ffffff;
        border: none;
        padding: 0.875rem 1.25rem;
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.15s;
        white-space: nowrap;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        flex-shrink: 0;
    }

    .search-bar-submit:hover { background: #1d4ed8; }

    .search-bar-clear {
        background: #f1f5f9;
        color: #64748b;
        border: none;
        border-left: 1px solid #e2e8f0;
        padding: 0.875rem 0.875rem;
        font-size: 1rem;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
        display: flex;
        align-items: center;
        flex-shrink: 0;
        text-decoration: none;
        line-height: 1;
    }

    .search-bar-clear:hover { background: #e2e8f0; color: #334155; }

    /* ── Event cards ────────────────────────────── */
    .event-card-modern {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(37, 99, 235, 0.08);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .event-card-modern:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 28px rgba(37, 99, 235, 0.15);
    }

    .event-card-image-wrapper {
        position: relative;
        width: 100%;
        padding-top: 65%;
        overflow: hidden;
        background: #e0f2fe;
    }

    .event-card-image {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        object-fit: cover;
    }

    .event-category-badge {
        position: absolute;
        top: 10px; right: 10px;
        background: rgba(255,255,255,0.95);
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 700;
        color: #334155;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.1);
    }

    .event-card-content {
        padding: 1rem 1.1rem 1.1rem;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .event-card-title-modern {
        font-size: 1rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 0.75rem;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .event-card-details {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        margin-top: auto;
    }

    .event-detail-item {
        display: flex;
        align-items: center;
        font-size: 0.82rem;
        color: #64748b;
    }

    .event-detail-item i { color: #94a3b8; width: 16px; flex-shrink: 0; }

    .event-price {
        margin-top: 0.5rem;
        padding-top: 0.6rem;
        border-top: 1px solid #e2e8f0;
        color: #1e293b;
        font-weight: 700;
    }

    .event-price i { color: #2563eb !important; }
    .event-price span { color: #1e293b; }

    @@media (max-width: 576px) {
        .search-bar { flex-wrap: wrap; border-radius: 10px; }
        .search-bar-input { min-width: 100%; border-bottom: 1px solid #e2e8f0; padding-left: 1rem; }
        .search-bar-date { width: auto; flex: 1; border-bottom: 1px solid #e2e8f0; }
        .search-bar-submit, .search-bar-clear { flex: 1; justify-content: center; }
    }
</style>

<div class="events-page">
    <div class="container-fluid" style="max-width: 1200px; margin: 0 auto;">

        <!-- Header -->
        <div class="text-center mb-4">
            <h1 style="font-size: 2rem; font-weight: 800; color: #1e3a8a; margin-bottom: 0.4rem;">Événements à venir</h1>
            <p style="color: #475569; font-size: 1rem;">Découvrez tous les événements et réservez vos places dès maintenant !</p>
        </div>

        <!-- Search bar — single row -->
        <div class="row justify-content-center mb-4">
            <div class="col-lg-9 col-xl-8">
                <form method="get">
                    <div class="search-bar" style="position: relative;">
                        <i class="bi bi-search search-bar-icon"></i>
                        <input type="text" name="searchTerm" class="search-bar-input"
                               placeholder="Rechercher un événement..."
                               value="@Model.SearchTerm" />
                        <div class="search-bar-divider"></div>
                        <input type="date" name="filterDate" class="search-bar-date"
                               value="@Model.FilterDate?.ToString("yyyy-MM-dd")" />
                        <button type="submit" class="search-bar-submit">
                            <i class="bi bi-search"></i>Rechercher
                        </button>
                        <a asp-action="Index" class="search-bar-clear" title="Effacer">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <!-- Events grid -->
        <div class="row g-4">
            @if (!Model.Events.Any())
            {
                <div class="col-12 text-center py-5">
                    <i class="bi bi-calendar-x" style="font-size: 3.5rem; color: #93c5fd; display: block; margin-bottom: 1rem;"></i>
                    <h3 style="color: #1e40af; font-weight: 700;">Aucun événement trouvé</h3>
                    <p style="color: #475569;">Essayez d'ajuster vos critères de recherche ou revenez plus tard.</p>
                </div>
            }
            else
            {
                @foreach (var item in Model.Events)
                {
                    var bgImage = !string.IsNullOrEmpty(item.PosterUrl)
                        ? item.PosterUrl
                        : (!string.IsNullOrEmpty(item.PosterBase64)
                            ? $"data:image/png;base64,{item.PosterBase64}"
                            : "https://placehold.co/400x300/dbeafe/2563eb?text=" + Uri.EscapeDataString(item.Name));
                    var minPrice = item.TicketTypes.Any() ? item.TicketTypes.Min(t => t.Price) : 0;

                    <div class="col-md-6 col-lg-4 col-xl-3">
                        <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                            <div class="event-card-modern">
                                <div class="event-card-image-wrapper">
                                    <img src="@bgImage" alt="@item.Name" class="event-card-image" />
                                    @if (item.Category != null)
                                    {
                                        <span class="event-category-badge">@item.Category.Name</span>
                                    }
                                </div>
                                <div class="event-card-content">
                                    <h3 class="event-card-title-modern">@item.Name</h3>
                                    <div class="event-card-details">
                                        <div class="event-detail-item">
                                            <i class="bi bi-calendar-event me-2"></i>
                                            <span>@item.Date.ToFrenchDateString("dd MMMM yyyy")</span>
                                        </div>
                                        <div class="event-detail-item">
                                            <i class="bi bi-clock me-2"></i>
                                            <span>@item.Date.ToString("HH:mm")</span>
                                        </div>
                                        <div class="event-detail-item">
                                            <i class="bi bi-geo-alt me-2"></i>
                                            <span>@(item.Venue?.Name ?? "À confirmer")</span>
                                        </div>
                                        <div class="event-detail-item event-price">
                                            <i class="bi bi-currency-exchange me-2"></i>
                                            <span>Dès @minPrice.ToString("N0") MGA</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            }
        </div>

    </div>
</div>
