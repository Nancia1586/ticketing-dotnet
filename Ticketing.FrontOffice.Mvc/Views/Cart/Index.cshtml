@model Ticketing.FrontOffice.Mvc.Models.Cart

@{
    ViewData["Title"] = "Panier";
}

<style>
    .checkout-page {
        background: linear-gradient(145deg, #dbeafe 0%, #bfdbfe 60%, #93c5fd 100%);
        min-height: calc(100vh - 72px);
        padding: 2rem 1.5rem;
    }

    .co-card {
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(37,99,235,0.08);
        overflow: hidden;
    }

    .co-card-header {
        padding: 0.875rem 1.25rem;
        border-bottom: 1px solid #e2e8f0;
        font-size: 0.8rem;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .co-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.75rem 1.25rem;
        border-bottom: 1px solid #f1f5f9;
        gap: 1rem;
    }

    .co-item:last-child { border-bottom: none; }

    .co-item-name {
        font-size: 0.875rem;
        font-weight: 600;
        color: #1e293b;
    }

    .co-item-sub {
        font-size: 0.75rem;
        color: #94a3b8;
        margin-top: 1px;
    }

    .co-item-price {
        font-size: 0.9rem;
        font-weight: 700;
        color: #2563eb;
        white-space: nowrap;
    }

    .co-remove {
        background: none;
        border: none;
        color: #cbd5e1;
        cursor: pointer;
        padding: 2px 4px;
        border-radius: 4px;
        font-size: 0.85rem;
        transition: color .15s;
        flex-shrink: 0;
    }

    .co-remove:hover { color: #ef4444; }

    .co-summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.6rem 1.25rem;
        font-size: 0.85rem;
        color: #64748b;
    }

    .co-summary-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.875rem 1.25rem;
        border-top: 2px solid #e2e8f0;
        font-weight: 700;
        color: #1e293b;
    }

    .co-summary-total span:last-child {
        font-size: 1.2rem;
        color: #2563eb;
    }

    .co-btn {
        width: 100%;
        padding: 0.875rem;
        background: #2563eb;
        color: #ffffff;
        border: none;
        border-radius: 8px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: background .2s;
        font-family: inherit;
        text-align: center;
        text-decoration: none;
        display: block;
    }

    .co-btn:hover { background: #1d4ed8; color: #fff; }

    .co-btn-ghost {
        display: block;
        width: 100%;
        padding: 0.6rem;
        text-align: center;
        font-size: 0.82rem;
        color: #64748b;
        text-decoration: none;
        border-radius: 8px;
        transition: background .15s;
    }

    .co-btn-ghost:hover { background: #f1f5f9; color: #334155; }
</style>

<div class="checkout-page">
    <div class="container-fluid" style="max-width: 900px; margin: 0 auto;">

        <div class="d-flex align-items-center gap-2 mb-3">
            <a asp-controller="Events" asp-action="Index"
               style="color:#2563eb; font-size:0.85rem; text-decoration:none; display:flex; align-items:center; gap:0.3rem;">
                <i class="bi bi-arrow-left"></i> Continuer les achats
            </a>
        </div>

        @if (!Model.Items.Any())
        {
            <div style="background:#fff; border-radius:12px; padding:3rem; text-align:center; box-shadow:0 2px 12px rgba(37,99,235,0.08);">
                <i class="bi bi-cart-x" style="font-size:3rem; color:#93c5fd; display:block; margin-bottom:1rem;"></i>
                <h3 style="color:#1e3a8a; font-weight:700; font-size:1.1rem;">Votre panier est vide</h3>
                <p style="color:#64748b; font-size:0.9rem; margin-bottom:1.5rem;">Explorez nos événements et ajoutez des billets.</p>
                <a asp-controller="Events" asp-action="Index" class="co-btn" style="max-width:200px; margin:0 auto;">
                    <i class="bi bi-search me-2"></i>Parcourir
                </a>
            </div>
        }
        else
        {
            <div class="row g-3 align-items-start">

                <!-- Left: order details -->
                <div class="col-lg-8">
                    <div class="co-card">
                        <div class="co-card-header">
                            Détails de la commande
                            <span style="float:right; font-weight:400; color:#94a3b8;">@Model.Items.Count article@(Model.Items.Count > 1 ? "s" : "")</span>
                        </div>
                        @foreach (var item in Model.Items)
                        {
                            <div class="co-item">
                                <div style="min-width:0; flex:1;">
                                    <div class="co-item-name text-truncate">@item.EventName</div>
                                    <div class="co-item-sub">
                                        @item.TicketTypeName
                                        @if (item.Seats.Any())
                                        {
                                            <span>· @string.Join(", ", item.Seats.Select(s => $"{(char)('A'+s.Row-1)}{s.Col}"))</span>
                                        }
                                        else
                                        {
                                            <span>· ×@item.Quantity</span>
                                        }
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-3">
                                    <span class="co-item-price">@item.Total.ToString("N0") Ar</span>
                                    <a asp-action="Remove" asp-route-id="@item.Id" class="co-remove" title="Retirer">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Right: summary + CTA -->
                <div class="col-lg-4">
                    <div class="co-card">
                        <div class="co-card-header">Résumé de la commande</div>
                        <div class="co-summary-row">
                            <span>Sous-total</span>
                            <span style="color:#1e293b; font-weight:600;">@Model.TotalAmount.ToString("N0") Ar</span>
                        </div>
                        <div class="co-summary-row">
                            <span>Frais de service</span>
                            <span style="color:#1e293b; font-weight:600;">0 Ar</span>
                        </div>
                        <div class="co-summary-total">
                            <span>Total</span>
                            <span>@Model.TotalAmount.ToString("N0") Ar</span>
                        </div>
                        <div style="padding: 0.875rem 1.25rem; display:flex; flex-direction:column; gap:0.5rem;">
                            <a asp-controller="Checkout" asp-action="Index" class="co-btn">
                                <i class="bi bi-credit-card me-2"></i>Commander
                            </a>
                        </div>
                    </div>
                </div>

            </div>
        }
    </div>
</div>
