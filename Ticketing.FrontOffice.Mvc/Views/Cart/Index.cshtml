@model Ticketing.FrontOffice.Mvc.Models.Cart

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container my-5">
    <h1 class="mb-4 display-5 fw-bold text-primary">Your Cart</h1>

    @if (!Model.Items.Any())
    {
        <div class="alert alert-info py-4">
            <h4 class="alert-heading"><i class="bi bi-info-circle me-2"></i>Your cart is empty</h4>
            <p class="mb-0">Go back to the <a asp-controller="Events" asp-action="Index" class="fw-bold text-decoration-none">events list</a> to find tickets.</p>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow border-0 mb-4">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light table-light">
                                    <tr>
                                        <th class="ps-4 py-3">Event</th>
                                        <th>Ticket</th>
                                        <th>Quantity</th>
                                        <th>Seats</th>
                                        <th>Price</th>
                                        <th>Total</th>
                                        <th class="pe-4 text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Items)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold text-primary">@item.EventName</td>
                                            <td><span class="badge bg-secondary">@item.TicketTypeName</span></td>
                                            <td class="fw-bold">@item.Quantity</td>
                                            <td>
                                                @if (item.Seats.Any())
                                                {
                                                    <small class="text-muted d-block" style="max-width: 150px; line-height: 1.2;">
                                                        @string.Join(", ", item.Seats.Select(s => $"R{s.Row} C{s.Col}"))
                                                    </small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">General Admission</span>
                                                }
                                            </td>
                                            <td>@item.Price.ToString("C")</td>
                                            <td class="fw-bold text-success">@item.Total.ToString("C")</td>
                                            <td class="pe-4 text-end">
                                                <a asp-action="Remove" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm" title="Remove">
                                                    <i class="bi bi-trash"></i> Remove
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-4">
                <div class="card shadow border-0 bg-light">
                    <div class="card-body p-4">
                        <h4 class="card-title fw-bold mb-4">Summary</h4>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal</span>
                            <span class="fw-bold">@Model.TotalAmount.ToString("C")</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-4">
                            <h3 class="fw-bold text-primary">Total</h3>
                            <h3 class="fw-bold text-primary">@Model.TotalAmount.ToString("C")</h3>
                        </div>
                        
                        <a asp-controller="Checkout" asp-action="Index" class="btn btn-primary w-100 btn-lg fw-bold shadow-sm">
                            Proceed to Checkout <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                        
                        <a asp-controller="Events" asp-action="Index" class="btn btn-link w-100 mt-2 text-decoration-none">
                            Continue Shopping
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
