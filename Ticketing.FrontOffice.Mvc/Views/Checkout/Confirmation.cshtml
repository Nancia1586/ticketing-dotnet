@model List<Ticketing.Core.Models.Reservation>

@{
    ViewData["Title"] = "Commande Confirmée";
    var totalPaid = Model.Sum(r => r.TotalAmount);
}

<div class="container my-5 no-print">
    <div class="text-center mb-5">
        <div class="display-1 text-success mb-3"><i class="bi bi-check-circle-fill"></i></div>
        <h1 class="display-4 fw-bold">Paiement Réussi !</h1>
        <p class="lead">Vos réservations ont été confirmées. Un email de confirmation a été envoyé à <strong>@Model.First().Email</strong>.</p>
        <button onclick="window.print()" class="btn btn-outline-primary btn-lg mt-3">
            <i class="bi bi-printer me-2"></i> Imprimer les Billets
        </button>
         <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg mt-3 ms-2">Retour à l'Accueil</a>
    </div>
</div>

<div class="container">
    <div class="row g-4">
        @foreach (var res in Model)
        {
            <div class="col-md-6 mx-auto print-full-width">
                <div class="card border-2 border-dark ticket-card">
                    <div class="card-body p-0">
                        <div class="row g-0">
                            <div class="col-8 p-4">
                                <h6 class="text-uppercase text-muted ls-1 mb-2">BILLET D'ÉVÉNEMENT</h6>
                                <h3 class="fw-bold mb-3">@res.Event.Name</h3>
                                <div class="mb-3">
                                    <i class="bi bi-calendar-event me-2"></i> @res.Event.Date.ToFrenchDateString("dd MMMM yyyy 'à' HH:mm")
                                </div>
                                <div class="mb-3">
                                    <i class="bi bi-person me-2"></i> @res.CustomerName
                                </div>
                                <div class="seat-info p-2 bg-light rounded mt-3">
                                    @if(res.Seats.Any())
                                    {
                                        var ticketTypeCache = ViewBag.TicketTypes as Dictionary<int, Ticketing.Core.Models.TicketType> ?? new Dictionary<int, Ticketing.Core.Models.TicketType>();
                                        
                                        // Group seats by ticket type
                                        var seatsByType = res.Seats
                                            .GroupBy(s => s.TicketTypeId)
                                            .OrderBy(g => {
                                                var tt = ticketTypeCache.ContainsKey(g.Key) ? ticketTypeCache[g.Key] : null;
                                                return tt?.Name ?? "";
                                            })
                                            .ToList();
                                        
                                        @foreach (var group in seatsByType)
                                        {
                                            var ticketType = ticketTypeCache.ContainsKey(group.Key) ? ticketTypeCache[group.Key] : null;
                                            var ticketTypeName = ticketType?.Name ?? "Inconnu";
                                            var seatCodes = group.OrderBy(s => s.Code).Select(s => s.Code).ToList();
                                            
                                            <div class="mb-2">
                                                <strong class="text-uppercase">@ticketTypeName:</strong>
                                                <span>@string.Join(", ", seatCodes)</span>
                                            </div>
                                        }
                                    }
                                    else 
                                    {
                                        <div>
                                            <strong>Entrée Générale :</strong>
                                            <span>@res.SeatCount billet(s)</span>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="col-4 bg-dark text-white p-4 d-flex flex-column align-items-center justify-content-center text-center">
                                <div class="qr-placeholder bg-white mb-3" style="width: 80px; height: 80px; padding: 5px;">
                                    <!-- Mock QR Code -->
                                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=@res.Id" alt="QR" width="100%" /> 
                                </div>
                                <small>Commande #@res.Id</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    @@media print {
        .no-print { display: none !important; }
        .print-full-width { flex: 0 0 100%; max-width: 100%; margin-bottom: 20px; }
        body { background-color: white; }
        .card { box-shadow: none !important; break-inside: avoid; }
    }
    .ls-1 { letter-spacing: 1px; }
    .ticket-card { border-style: dashed; }
</style>

<script>
    // Clear all selected seats from localStorage after successful checkout
    document.addEventListener('DOMContentLoaded', function() {
        // Get all event IDs from reservations
        const eventIds = @Html.Raw(Json.Serialize(Model.Select(r => r.EventId).Distinct()));
        
        eventIds.forEach(eventId => {
            const storageKey = `selectedSeats_${eventId}`;
            localStorage.removeItem(storageKey);
        });
        
        // Also clear any generic selection keys
        Object.keys(localStorage).forEach(key => {
            if (key.startsWith('selectedSeats_')) {
                localStorage.removeItem(key);
            }
        });
    });
</script>