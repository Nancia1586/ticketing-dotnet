@{
    ViewData["Title"] = "Connexion";
}

<style>
    .login-page {
        background: linear-gradient(145deg, #dbeafe 0%, #bfdbfe 60%, #93c5fd 100%);
        min-height: calc(100vh - 72px);
        display: flex;
        align-items: center;
        padding: 2.5rem 1.5rem;
    }

    .login-input {
        width: 100%;
        padding: 0.85rem 1rem;
        border: 1.5px solid #cbd5e1;
        border-radius: 8px;
        font-size: 0.95rem;
        color: #1e293b;
        background: #ffffff;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
        font-family: inherit;
    }

    .login-input:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
    }

    .login-input::placeholder { color: #94a3b8; }

    .input-wrapper {
        position: relative;
    }

    .input-wrapper .password-toggle {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #94a3b8;
        cursor: pointer;
        padding: 0;
        line-height: 1;
        font-size: 1.1rem;
    }

    .input-wrapper .password-toggle:hover { color: #475569; }

    .login-submit {
        width: 100%;
        padding: 0.875rem;
        background-color: #2563eb;
        color: #ffffff;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.2s;
        font-family: inherit;
    }

    .login-submit:hover { background-color: #1d4ed8; }

    .preamble-feature {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .preamble-feature-icon {
        width: 32px;
        height: 32px;
        background: rgba(37, 99, 235, 0.12);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        color: #2563eb;
        font-size: 0.9rem;
    }
</style>

<div class="login-page">
    <div class="container-fluid" style="max-width: 960px; margin: 0 auto;">
        <div class="row align-items-center g-5">

            <!-- Left: Preamble -->
            <div class="col-lg-5">
                <div class="d-flex align-items-center mb-4 gap-2">
                    <i class="bi bi-ticket-perforated-fill" style="font-size: 2rem; color: #2563eb;"></i>
                    <span style="font-size: 1.75rem; font-weight: 800; color: #1e3a8a; letter-spacing: -0.5px;">tiktek</span>
                </div>

                <h2 style="font-weight: 800; color: #1e293b; font-size: 1.5rem; margin-bottom: 0.5rem;">
                    Bon retour !
                </h2>
                <p style="color: #475569; font-size: 0.92rem; line-height: 1.6; margin-bottom: 1.75rem;">
                    Connectez-vous pour accéder à vos billets, suivre vos réservations et découvrir les événements à venir.
                </p>

                <div class="preamble-feature">
                    <div class="preamble-feature-icon"><i class="bi bi-ticket-perforated"></i></div>
                    <div>
                        <div style="font-size: 0.875rem; font-weight: 700; color: #1e293b;">Vos billets en un clic</div>
                        <div style="font-size: 0.8rem; color: #64748b;">Retrouvez toutes vos réservations depuis votre espace personnel.</div>
                    </div>
                </div>

                <div class="preamble-feature">
                    <div class="preamble-feature-icon"><i class="bi bi-bell"></i></div>
                    <div>
                        <div style="font-size: 0.875rem; font-weight: 700; color: #1e293b;">Alertes et confirmations</div>
                        <div style="font-size: 0.8rem; color: #64748b;">Recevez vos billets par email dès la confirmation de paiement.</div>
                    </div>
                </div>

                <div class="preamble-feature">
                    <div class="preamble-feature-icon"><i class="bi bi-shield-check"></i></div>
                    <div>
                        <div style="font-size: 0.875rem; font-weight: 700; color: #1e293b;">Paiement sécurisé</div>
                        <div style="font-size: 0.8rem; color: #64748b;">Transactions chiffrées via Papi — Mvola, Orange Money, Airtel, VISA.</div>
                    </div>
                </div>
            </div>

            <!-- Right: Form Card -->
            <div class="col-lg-7">
                <div style="background: #ffffff; border-radius: 16px; padding: 2.25rem 2rem; box-shadow: 0 4px 24px rgba(37, 99, 235, 0.1);">
                    <h2 style="font-weight: 700; color: #1e293b; font-size: 1.4rem; margin-bottom: 1.5rem;">
                        Se connecter
                    </h2>

                    <form method="post" asp-controller="Account" asp-action="Login" autocomplete="off">
                        <div asp-validation-summary="All" class="text-danger mb-3" style="font-size: 0.85rem; display: none;"></div>
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                        <div style="display: flex; flex-direction: column; gap: 0.875rem; margin-bottom: 1rem;">
                            <div class="input-wrapper">
                                <input type="email" name="email" class="login-input" placeholder="Adresse email *" required />
                            </div>

                            <div class="input-wrapper">
                                <input type="password" name="password" class="login-input" placeholder="Mot de passe *"
                                       id="passwordInput" style="padding-right: 2.75rem;" required />
                                <button type="button" class="password-toggle" onclick="togglePassword()" tabindex="-1">
                                    <i class="bi bi-eye" id="passwordIcon"></i>
                                </button>
                            </div>
                        </div>

                        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem;">
                            <label style="display: flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; color: #64748b; cursor: pointer;">
                                <input type="checkbox" name="rememberMe" style="accent-color: #2563eb;" />
                                Se souvenir de moi
                            </label>
                            <a href="#" style="font-size: 0.85rem; color: #2563eb; text-decoration: none; font-weight: 500;">
                                Mot de passe oublié ?
                            </a>
                        </div>

                        <button type="submit" class="login-submit">Se connecter</button>

                        <!-- Demo accounts -->
                        <div style="margin-top: 1.25rem; padding: 0.875rem; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 8px;">
                            <p style="font-size: 0.72rem; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.6rem;">
                                <i class="bi bi-info-circle me-1"></i>Comptes de démonstration
                            </p>
                            <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                                <button type="button" onclick="fillCredentials('contact@passion-events.mg','Organizer123!')"
                                        style="display:flex; align-items:center; justify-content:space-between; padding:0.45rem 0.75rem; background:#ffffff; border:1px solid #e2e8f0; border-radius:6px; cursor:pointer; transition:border-color .15s; font-family:inherit;">
                                    <span style="font-size:0.8rem; color:#1e293b; font-weight:600;">
                                        <i class="bi bi-person-badge me-1" style="color:#2563eb;"></i>Organisateur
                                    </span>
                                    <span style="font-size:0.75rem; color:#64748b; font-family:monospace;">contact@passion-events.mg</span>
                                </button>
                            </div>
                        </div>

                        <p class="text-center mt-3 mb-0" style="color: #64748b; font-size: 0.875rem;">
                            Pas encore de compte ?
                            <a asp-controller="Organizer" asp-action="Register"
                               style="color: #2563eb; text-decoration: none; font-weight: 600;">
                                Devenir organisateur
                            </a>
                        </p>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    function fillCredentials(email, password) {
        document.querySelector('input[name="email"]').value = email;
        document.getElementById('passwordInput').value = password;
    }

    function togglePassword() {
        const input = document.getElementById('passwordInput');
        const icon  = document.getElementById('passwordIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('bi-eye', 'bi-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('bi-eye-slash', 'bi-eye');
        }
    }

    // Show validation summary only when it has errors
    const summary = document.querySelector('[data-valmsg-summary]');
    if (summary && summary.querySelector('li')) {
        summary.style.display = '';
    }
</script>
