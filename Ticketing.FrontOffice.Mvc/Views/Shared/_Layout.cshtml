<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Tiktek</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ticketplace-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Ticketing.FrontOffice.Mvc.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- Fixed Header -->
    <header class="fixed-header">
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container-fluid px-4">
                <div class="d-flex align-items-center flex-grow-1">
                    <!-- Logo -->
                    <a class="navbar-brand logo-brand me-4" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-ticket-perforated-fill me-2"></i>
                        <span class="logo-text">Tiktek</span>
                    </a>

                    <!-- Search Bar and Location Input (Eventbrite Style) -->
                    <form class="eventbrite-search-form d-flex align-items-center flex-grow-1 me-3" asp-controller="Events" asp-action="Index" method="get">
                        <div class="eventbrite-search-wrapper me-2">
                            <i class="bi bi-search eventbrite-search-icon"></i>
                            <input type="text" name="searchTerm" class="eventbrite-search-input" placeholder="Rechercher des événements" value="@Context.Request.Query["searchTerm"]">
                        </div>
                        <div class="eventbrite-location-wrapper me-2">
                            <i class="bi bi-geo-alt eventbrite-location-icon"></i>
                            <input type="text" name="location" class="eventbrite-location-input" placeholder="Votre Localisation" value="@Context.Request.Query["location"]">
                        </div>
                        <button type="submit" class="eventbrite-search-btn">
                            <i class="bi bi-search"></i>
                        </button>
                    </form>
                </div>

                <!-- Mobile Menu Toggle -->
                <button class="navbar-toggler mobile-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Navigation Links (Right Side) -->
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav nav-links ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Events" asp-action="Index">Trouver des Événements</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Organizer" asp-action="Register">Créer des Événements</a>
                        </li>

                        @await Component.InvokeAsync("CartDropdown")
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Customer" asp-action="MyReservations">Trouver mes billets</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle btn-login" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle me-1"></i> @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 mt-2" aria-labelledby="userDropdown">
                                    <li><a class="dropdown-item py-2" asp-controller="Customer" asp-action="MyReservations"><i class="bi bi-clock-history me-2 text-primary"></i> Mes Réservations</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item text-danger py-2"><i class="bi bi-box-arrow-right me-2"></i> Déconnexion</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link btn-login" asp-controller="Account" asp-action="Login">
                                    Log In
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Main Content (with padding for fixed header) -->
    <main role="main" class="main-content">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="site-footer">
        <div class="container">
            <div class="row py-5">
                <div class="col-md-4 mb-4 mb-md-0">
                    <h5 class="footer-title">Tiktek</h5>
                    <p class="footer-text">Votre destination de choix pour découvrir et réserver des événements incroyables.</p>
                </div>
                <div class="col-md-2 mb-4 mb-md-0">
                    <h6 class="footer-heading">Quick Links</h6>
                    <ul class="footer-links">
                        <li><a asp-controller="Events" asp-action="Index">Événements</a></li>
                        <li><a asp-controller="Organizer" asp-action="Register">Devenir organisateur</a></li>
                        <li><a href="#contact">Contact</a></li>
                    </ul>
                </div>
                <div class="col-md-2 mb-4 mb-md-0">
                    <h6 class="footer-heading">Support</h6>
                    <ul class="footer-links">
                        <li><a asp-controller="Customer" asp-action="MyReservations">Mes Réservations</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy">Politique de Confidentialité</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="footer-heading">Stay Connected</h6>
                    <div class="social-links">
                        <a href="#" class="social-link"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-link"><i class="bi bi-twitter"></i></a>
                        <a href="#" class="social-link"><i class="bi bi-instagram"></i></a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom text-center py-3 border-top" style="border-color: var(--border-color) !important;">
                <p class="mb-0" style="color: var(--text-secondary);">&copy; 2025 Tiktek. Tous droits réservés.</p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/carousel.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
